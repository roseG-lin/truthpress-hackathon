{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".tmp-tests",
    "rootDir": "."
  },
  "include": [
    "src/lib/**/*.ts",
    "src/lib/__tests__/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
