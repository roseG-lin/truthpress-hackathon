# =========================================================
# Agent 求真报社 × SecondMe
# Environment Template
# Copy this file to `.env.local` for local development.
# =========================================================

# ---------------------------------------------------------
# LLM / DeepSeek / OpenAI-compatible API
# ---------------------------------------------------------
# Preferred generic names used by the Next.js debate engine:
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat

# Optional compatibility aliases:
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_BASE_URL=
API_KEY=
BASE_URL=

# ---------------------------------------------------------
# SecondMe OAuth
# ---------------------------------------------------------
SECONDME_CLIENT_ID=your_secondme_client_id
SECONDME_CLIENT_SECRET=your_secondme_client_secret
SECONDME_CALLBACK_URL=http://localhost:3000/api/auth/callback
TOKEN_ENCRYPTION_KEY=

# Public URLs used by the frontend / auth routes:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SECONDME_OAUTH_URL=https://second.me/oauth2/authorize
NEXT_PUBLIC_SECONDME_API_URL=https://api.second.me

# ---------------------------------------------------------
# Search API (Agent B 联网核查)
# ---------------------------------------------------------
# Tavily Search API - 专为 AI 设计，支持中文，免费 1,000 次/月
# 注册地址: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ---------------------------------------------------------
# Database
# ---------------------------------------------------------
DATABASE_URL="file:./prisma/dev.db"

# ---------------------------------------------------------
# Node / app environment
# ---------------------------------------------------------
NODE_ENV=development
