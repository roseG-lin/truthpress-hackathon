# ============================================
# TruthPress 生产环境配置模板
# ============================================
# 部署到 Railway/Render 时使用此配置
# 请填入你的实际配置值

# --------------------------------------------
# LLM API 配置（必填）
# --------------------------------------------
# 获取 DeepSeek API Key: https://platform.deepseek.com/
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat

# --------------------------------------------
# SecondMe OAuth 配置（必填）
# --------------------------------------------
# 用户需要在 SecondMe 开发者平台申请自己的 OAuth 凭证
# 获取地址: https://second.me/developer
SECONDME_CLIENT_ID=your-secondme-client-id
SECONDME_CLIENT_SECRET=your-secondme-client-secret
SECONDME_CALLBACK_URL=https://your-domain.railway.app/api/auth/callback
NEXT_PUBLIC_APP_URL=https://your-domain.railway.app
NEXT_PUBLIC_SECONDME_OAUTH_URL=https://second.me/oauth2/authorize
NEXT_PUBLIC_SECONDME_API_URL=https://api.second.me

# --------------------------------------------
# 数据库配置（Railway 自动提供）
# --------------------------------------------
# Railway 会自动添加 DATABASE_URL 环境变量
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=railway-provided-database-url

# --------------------------------------------
# 运行环境
# --------------------------------------------
NODE_ENV=production
PORT=3000
